{
  "name": "uniswap-agentic-trader",
  "version": "1.0.0",
  "description": "AI-supervised trading agent that uses the Uniswap Trading API to execute real on-chain swaps on Base",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "scan": "ts-node src/scan.ts",
    "demo": "ts-node scripts/demo.ts",
    "typecheck": "tsc --noEmit",
    "compile": "ts-node src/compile.ts",
    "test": "vitest run"
  },
  "keywords": [
    "uniswap",
    "trading",
    "agent",
    "defi",
    "base",
    "uniswapx"
  ],
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.5",
    "solc": "^0.8.34",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  }
}
